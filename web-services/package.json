{
  "name": "@axion/web-services",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint --filter=!@axion/worker",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "prisma:generate": "cd ./packages/db && bunx prisma generate && cd ../..",
    "backend": "cd ./apps/backend && bun run index.ts",
    "worker": "cd ./apps/worker && bun run index.ts",
    "ws-relayer": "cd ./apps/ws-relayer && bun run index.ts",
    "depin-ws-relayer": "cd ./apps/depin-ws-relayer && bun run index.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "bunx prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.6.0",
    "turbo": "^2.5.4",
    "typescript": "5.8.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.2.4",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@tabler/icons-react": "^3.44.0",
    "prisma": "^7.8.0"
  }
}
